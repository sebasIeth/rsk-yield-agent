# Anthropic API key for Claude AI
ANTHROPIC_API_KEY=sk-ant-...

# RSK Network
RSK_RPC_URL=https://public-node.testnet.rsk.co

# Contract addresses (from deployment)
VAULT_ADDRESS=0x...
ROUTER_ADDRESS=0x...

# Agent keeper wallet
AGENT_PRIVATE_KEY=0x...

# Agent HTTP server port
AGENT_PORT=3001

# Database (optional, uses mock data if not set)
DATABASE_URL=postgresql://user:pass@localhost:5432/rsk_yield_agent

# RBTC price in USD
RBTC_PRICE_USD=95000

# Claude model (optional)
CLAUDE_MODEL=claude-sonnet-4-5-20250514

# Log level
LOG_LEVEL=info
