FROM node:20-alpine

RUN apk add --no-cache openssl

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY prisma/ ./prisma/
RUN npx prisma generate

COPY . .

# NEXT_PUBLIC vars must be present at build time
ARG NEXT_PUBLIC_CHAIN_ID=31
ARG NEXT_PUBLIC_VAULT_ADDRESS=0xa705286a7ed025d46F2f7cF215654e0c1115fbCf
ARG NEXT_PUBLIC_ROUTER_ADDRESS=0xABca8c0a645F7DD77112cCD26515b6E5125Fa36B
ARG NEXT_PUBLIC_RBTC_PRICE_USD=95000
ENV NEXT_PUBLIC_CHAIN_ID=$NEXT_PUBLIC_CHAIN_ID
ENV NEXT_PUBLIC_VAULT_ADDRESS=$NEXT_PUBLIC_VAULT_ADDRESS
ENV NEXT_PUBLIC_ROUTER_ADDRESS=$NEXT_PUBLIC_ROUTER_ADDRESS
ENV NEXT_PUBLIC_RBTC_PRICE_USD=$NEXT_PUBLIC_RBTC_PRICE_USD

RUN npm run build

ENV PORT=4000
EXPOSE 4000

CMD ["sh", "-c", "npx prisma db push --accept-data-loss && npm start -- -p 4000"]
